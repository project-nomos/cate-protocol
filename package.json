{
  "name": "cate-protocol",
  "private": true,
  "description": "Consumer Agent Trust Envelope — identity, E2EE, consent, rate limits, and message stamps for agent-to-agent communication",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json}": "oxfmt --write",
    "*.{ts,tsx,js}": "oxlint"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.11.0"
}
